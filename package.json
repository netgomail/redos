{
  "name": "redos",
  "version": "0.8.0",
  "main": "src/app.tsx",
  "dependencies": {
    "ink": "6.8.0",
    "react": "19.2.0"
  },
  "description": "Консольная утилита для аудита безопасности Linux",
  "keywords": [
    "cli",
    "security",
    "audit",
    "hardening",
    "linux"
  ],
  "license": "MIT",
  "pkg": {
    "assets": [
      "dist/yoga.wasm"
    ],
    "targets": [
      "node22-linux-x64",
      "node22-macos-x64"
    ]
  },
  "scripts": {
    "start": "bun src/app.tsx",
    "build": "bun run bunbuild.mjs",
    "build:linux": "bun run bunbuild.mjs --linux",
    "build:mac": "bun run bunbuild.mjs --mac"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.10"
  }
}
